# Скопируйте в .env и заполните. Файл .env не коммитьте.

# Let's Encrypt
ACME_EMAIL=you@example.com

# reg.ru DNS API (Traefik / lego). Часто это отдельный пароль API из кабинета reg.ru.
REGRU_USERNAME=
REGRU_PASSWORD=
REGRU_PROPAGATION_TIMEOUT=300
REGRU_POLLING_INTERVAL=5

# Общий секрет frpc ↔ frps (придумайте длинную случайную строку)
FRP_TOKEN=

# Bearer для управления белым списком IP (тот же токен для localhost и для HTTPS).
WHITELIST_ADMIN_TOKEN=
# Публичный хост только для POST /white-list (TLS через Traefik). Нужна DNS A/AAAA запись на этот сервер.
# Локально: curl -X POST http://127.0.0.1:9180/white-list ...
# Снаружи:  curl https://whitelist.limpopo113.ru/white-list -H "Authorization: Bearer …" (GET — список; POST — замена)
