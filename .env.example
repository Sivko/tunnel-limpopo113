# Скопируйте в .env и заполните. Файл .env не коммитьте.

# Let's Encrypt
ACME_EMAIL=you@example.com

# reg.ru DNS API (Traefik / lego). Часто это отдельный пароль API из кабинета reg.ru.
REGRU_USERNAME=
REGRU_PASSWORD=
REGRU_PROPAGATION_TIMEOUT=300
REGRU_POLLING_INTERVAL=5

# Общий секрет frpc ↔ frps (придумайте длинную случайную строку)
FRP_TOKEN=
